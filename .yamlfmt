---
# yamlfmt configuration
# See: https://github.com/google/yamlfmt
doublestar: true
formatter:
  type: basic
  include_document_start: true
  retain_line_breaks_single: true

output_format: line

include:
  - "**/*.{yaml,yml}"

exclude:
  - "charts/services/templates/**"
  - "charts/services/tests/**"
  - "molecule/**"
  - "roles/**"

gitignore_excludes: true
